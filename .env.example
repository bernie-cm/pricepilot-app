# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# ── Environment ────────────────────────────────────────────────────────────────
ENVIRONMENT=dev   # dev | staging | prod

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=pricepilot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=pricepilot
DATABASE_URL=postgresql+asyncpg://pricepilot:changeme@localhost:5432/pricepilot

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_USER=pricepilot
RABBITMQ_PASSWORD=changeme
RABBITMQ_URL=amqp://pricepilot:changeme@localhost:5672/

# ── Mailgun ────────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
